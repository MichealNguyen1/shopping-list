# Copy file này thành .env và điền giá trị thực

# MongoDB Atlas connection string
# Lấy từ: Atlas Console → Connect → Drivers → copy connection string
# Thay <password> bằng mật khẩu thực
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Tên database (tự tạo nếu chưa có)
MONGODB_DB=shopping_list

# URL frontend — thay bằng URL Vercel sau khi deploy
# Khi dev local: http://localhost:5173 (Vite default port)
FRONTEND_URL=http://localhost:5173
